# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001). In single-listener mode this serves both the
# dashboard and the OpenAI-compatible API.
PORT=3001

# Bind address. The default keeps LLMHarbor reachable only from this machine.
# Prefer split mode below instead of HOST=0.0.0.0 if you want a public API.
HOST=127.0.0.1

# Split mode: serve the dashboard only on a private Tailscale/VPN address while
# exposing only the OpenAI-compatible /v1 API on the public listener.
# The CLI can fill these for you with: llmharbor tailscale
# Or pass them directly for one start:
#   llmharbor start --dashboard-host 100.x.y.z --dashboard-port 3002 --public-api-host 0.0.0.0 --public-api-port 3001 --trusted-network
# LLMHARBOR_DASHBOARD_HOST=100.x.y.z
# LLMHARBOR_DASHBOARD_PORT=3002
# LLMHARBOR_DASHBOARD_TRUSTED_NETWORK=1
# LLMHARBOR_PUBLIC_API_HOST=0.0.0.0
# LLMHARBOR_PUBLIC_API_PORT=3001

# Legacy remote-control switch. Prefer LLMHARBOR_DASHBOARD_TRUSTED_NETWORK=1
# with the dashboard listener bound to Tailscale/VPN only.
# LLMHARBOR_ALLOW_REMOTE_CONTROL_PLANE=0

# Comma-separated extra origins allowed to call the API from a browser.
# localhost:5173, 127.0.0.1:5173, [::1]:5173 are allowed by default for the
# Vite dev dashboard. Only set this if you serve the dashboard from a
# different host than the API (e.g. http://my-server.local).
# DASHBOARD_ORIGINS=http://my-server.local,http://192.168.1.50
